---
import Layout from "../layouts/Layout.astro";
import Section from "../components/common/Section.astro";

const tecnologias = [
  { nombre: "LangChain", tipo: "framework", nivel: "Avanzado" },
  { nombre: "LangGraph", tipo: "framework", nivel: "Avanzado" },
  { nombre: "CrewAI", tipo: "framework", nivel: "Avanzado" },
  { nombre: "MCP (Model Context Protocol)", tipo: "protocol", nivel: "Avanzado" },
  { nombre: "n8n", tipo: "platform", nivel: "Avanzado" },
  { nombre: "Autogen Studio", tipo: "platform", nivel: "Intermedio" },
  { nombre: "Claude API", tipo: "llm", nivel: "Avanzado" },
  { nombre: "Ollama", tipo: "llm", nivel: "Avanzado" },
  { nombre: "Go + AI", tipo: "integration", nivel: "Avanzado" },
  { nombre: "RAG Systems", tipo: "technique", nivel: "Avanzado" },
  { nombre: "Vector Databases", tipo: "database", nivel: "Avanzado" },
  { nombre: "Agent Orchestration", tipo: "technique", nivel: "Avanzado" },
];

const casos = [
  {
    titulo: "Automatización de Procesos con Agentes IA",
    descripcion: "Diseño e implementación de pipelines automatizados que combinan múltiples agentes IA para ejecutar workflows complejos de negocio.",
    tags: ["LangGraph", "CrewAI", "Python"],
  },
  {
    titulo: "Sistemas RAG para Retrieval Augment Generation",
    descripcion: "Construcción de sistemas RAG escalables con chunking inteligente, embeddings optimizados y re-ranking para recuperación de contexto precisa.",
    tags: ["RAG", "PostgreSQL", "pgvector"],
  },
  {
    titulo: "Orquestación Multi-Agente",
    descripcion: "Desarrollo de arquitecturas donde múltiples agentes especializados colaboran para resolver tareas complejas de manera autónoma.",
    tags: ["LangChain", "MCP", "Autogen"],
  },
  {
    titulo: "Integración MCP para Herramientas",
    descripcion: "Implementación del Model Context Protocol para conectar agentes IA con APIs externas, bases de datos y servicios empresariales.",
    tags: ["MCP", "REST API", "Webhooks"],
  },
];

const busquedas = [
  "ingeniero IA agentica Chile",
  "experto LangChain Latinoamerica",
  "desarrollor CrewAI Chile",
  "agentes IA autonomos empresa",
  "consultor automatización IA",
  "AI engineer Latin America",
  "LangGraph specialist near me",
  "autonomous AI agents developer",
  "RAG system implementation",
  "MCP model context protocol expert",
];
---

<Layout
  title="AI Agents Engineer • Inteligencia Artificial Agéntica"
  description="Jaime Hernández - AI Agents Engineer especializado en LangChain, LangGraph, CrewAI y MCP. Building autonomous AI systems and intelligent automation workflows."
  canonical="https://jaimehernandez.dev/agent"
>
  <Section class="my-16">
    <div class="max-w-4xl mx-auto">
      
      <!-- Hero -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full text-sm font-semibold mb-6">
          🤖 AI Agents Specialist
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          AI Agents <span class="text-purple-600">Engineer</span>
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
          Building autonomous AI systems, intelligent workflows, and multi-agent orchestration. 
          From prototype to production.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-16">
        <div class="text-center p-4 bg-gradient-to-br from-purple-50 to-blue-50 dark:from-purple-900/20 dark:to-blue-900/20 rounded-xl">
          <p class="text-3xl font-bold text-purple-600">3+</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Proyectos IA Agéntica</p>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-blue-50 to-green-50 dark:from-blue-900/20 dark:to-green-900/20 rounded-xl">
          <p class="text-3xl font-bold text-blue-600">8+</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Años Backend</p>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-green-50 to-yellow-50 dark:from-green-900/20 dark:to-yellow-900/20 rounded-xl">
          <p class="text-3xl font-bold text-green-600">50M+</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">SKUs procesados</p>
        </div>
        <div class="text-center p-4 bg-gradient-to-br from-yellow-50 to-orange-50 dark:from-yellow-900/20 dark:to-orange-900/20 rounded-xl">
          <p class="text-3xl font-bold text-orange-600">5</p>
          <p class="text-sm text-gray-600 dark:text-gray-400">Países LATAM</p>
        </div>
      </div>

      <!-- Qué hago -->
      <div class="prose prose-lg dark:prose-invert max-w-none mb-16">
        <h2 class="text-2xl font-bold mb-6">¿Qué hago?</h2>
        <p class="text-lg leading-relaxed">
          Diseño y construyo <strong>sistemas de inteligencia artificial agéntica</strong>: 
          sistemas donde modelos de lenguaje trabajan de manera autónoma para completar tareas complejas, 
          tomar decisiones, y ejecutar acciones.
        </p>
        <p>
          Mi enfoque combina <strong>arquitectura de software robusta</strong> con las últimas 
          innovaciones en IA: LangChain, LangGraph, CrewAI, MCP, y modelos de lenguaje de última generación.
        </p>
      </div>

      <!-- Tecnologías -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold mb-8 text-center">Tecnologías</h2>
        
        <div class="grid md:grid-cols-3 gap-4">
          {tecnologias.map(tech => (
            <div class="flex items-center gap-3 p-4 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-600 transition-colors">
              <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
              <div>
                <p class="font-semibold">{tech.nombre}</p>
                <p class="text-xs text-gray-500">{tech.nivel}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Casos de Uso -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold mb-8 text-center">Casos de Uso</h2>
        
        <div class="space-y-6">
          {casos.map(caso => (
            <div class="p-6 bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700">
              <h3 class="font-semibold text-lg mb-2">{caso.titulo}</h3>
              <p class="text-gray-600 dark:text-gray-400 mb-4">{caso.descripcion}</p>
              <div class="flex flex-wrap gap-2">
                {caso.tags.map(tag => (
                  <span class="px-3 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 rounded-full text-sm">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Para quién -->
      <div class="mb-16">
        <h2 class="text-2xl font-bold mb-8 text-center">¿Para quién?</h2>
        
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-6 bg-blue-50 dark:bg-blue-900/20 rounded-xl">
            <h3 class="font-semibold mb-3">🏢 Empresas</h3>
            <ul class="space-y-2 text-sm">
              <li>• Automatización de procesos con IA</li>
              <li>• Chatbots y asistentes inteligentes</li>
              <li>• Sistemas de análisis predictivo</li>
              <li>• Integración con sistemas legacy</li>
            </ul>
          </div>
          <div class="p-6 bg-green-50 dark:bg-green-900/20 rounded-xl">
            <h3 class="font-semibold mb-3">🚀 Startups</h3>
            <ul class="space-y-2 text-sm">
              <li>• Prototipado rápido de ideas con IA</li>
              <li>• MVPs con agentes autónomos</li>
              <li>• Escalabilidad desde día uno</li>
              <li>• Consultoría técnica estratégica</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- SEO Keywords -->
      <div class="mb-16 p-6 bg-gray-100 dark:bg-gray-800/50 rounded-xl">
        <h2 class="text-lg font-semibold mb-4">Búsquedas relacionadas</h2>
        <div class="flex flex-wrap gap-2">
          {busquedas.map(busqueda => (
            <span class="px-3 py-1 bg-white dark:bg-gray-700 rounded-full text-xs text-gray-600 dark:text-gray-300">
              {busqueda}
            </span>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <h2 class="text-2xl font-bold mb-6">¿Tienes un proyecto en mente?</h2>
        <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-xl mx-auto">
          Conversemos sobre cómo la IA agéntica puede transformar tu negocio. 
          Desde la conceptualización hasta la implementación en producción.
        </p>
        <div class="flex justify-center gap-4 flex-wrap">
          <a 
            href="https://www.linkedin.com/in/devjaime/"
            class="px-8 py-4 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition-colors font-semibold"
            target="_blank"
            rel="noopener"
          >
            LinkedIn →
          </a>
          <a 
            href="/blog"
            class="px-8 py-4 border-2 border-purple-600 text-purple-600 dark:text-purple-400 dark:border-purple-400 rounded-xl hover:bg-purple-50 dark:hover:bg-purple-900/20 transition-colors font-semibold"
          >
            Ver Blog
          </a>
        </div>
      </div>

    </div>
  </Section>
</Layout>

<style>
  .prose strong {
    @apply text-purple-600 dark:text-purple-400;
  }
</style>
