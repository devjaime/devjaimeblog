---
import Layout from "../layouts/Layout.astro";

const title = "Agent Status • Jaime Hernández";
const description = "Live status of my AI agent system. See what I'm working on in real-time.";
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    
    <!-- Header -->
    <div class="text-center mb-12">
      <div id="status-badge" class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 rounded-full text-sm font-semibold mb-4">
        <span id="status-dot" class="w-3 h-3 bg-yellow-500 rounded-full animate-pulse"></span>
        <span id="status-text">Checking...</span>
      </div>
      <h1 class="text-4xl font-bold mb-4">Agent Status</h1>
      <p class="text-gray-600 dark:text-gray-400">Live status of my AI agent system</p>
      <p class="text-sm text-gray-500 mt-2">Last updated: <span id="last-update">-</span></p>
    </div>

    <!-- Agent Info -->
    <div class="grid md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="font-semibold mb-2">🤖 Agent</h3>
        <p id="agent-name" class="text-2xl font-bold text-purple-600">-</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="font-semibold mb-2">⏱️ Uptime</h3>
        <p id="uptime" class="text-2xl font-bold text-green-600">-</p>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-xl p-6 border border-gray-200 dark:border-gray-700">
        <h3 class="font-semibold mb-2">📊 Active Sessions</h3>
        <p id="sessions-count" class="text-2xl font-bold text-blue-600">-</p>
      </div>
    </div>

    <!-- Current Task -->
    <div class="bg-gradient-to-br from-purple-50 to-blue-50 dark:from-purple-900/20 dark:to-blue-900/20 rounded-xl p-6 mb-8">
      <h2 class="font-semibold text-lg mb-4">🚀 Current Task</h2>
      <div id="current-task" class="text-gray-700 dark:text-gray-300">
        <p class="italic">Loading...</p>
      </div>
    </div>

    <!-- Scheduled Jobs -->
    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 mb-8 border border-gray-200 dark:border-gray-700">
      <h2 class="font-semibold text-lg mb-4">📅 Scheduled Jobs</h2>
      <div id="jobs-list" class="space-y-3">
        <p class="text-gray-500 italic">Loading...</p>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="bg-white dark:bg-gray-800 rounded-xl p-6 mb-8 border border-gray-200 dark:border-gray-700">
      <h2 class="font-semibold text-lg mb-4">📝 Recent Activity</h2>
      <div id="activity-log" class="space-y-2 text-sm">
        <p class="text-gray-500 italic">Loading...</p>
      </div>
    </div>

    <!-- Errors/Warnings -->
    <div id="errors-section" class="hidden bg-red-50 dark:bg-red-900/20 rounded-xl p-6 mb-8 border border-red-200 dark:border-red-800">
      <h2 class="font-semibold text-lg mb-4">⚠️ Errors</h2>
      <div id="errors-list" class="space-y-2 text-sm text-red-700 dark:text-red-400"></div>
    </div>

    <!-- Refresh Button -->
    <div class="text-center">
      <button 
        id="refresh-btn"
        class="px-6 py-3 bg-purple-600 text-white rounded-xl hover:bg-purple-700 transition-colors font-semibold"
      >
        🔄 Refresh Status
      </button>
    </div>

  </div>

  <script is:inline>
    const API_URL = "/api/agent-status.json";
    
    async function fetchStatus() {
      try {
        const response = await fetch(API_URL + "?t=" + Date.now());
        const data = await response.json();
        updateUI(data);
      } catch (error) {
        console.error("Failed to fetch status:", error);
        document.getElementById("status-text").textContent = "Error";
        document.getElementById("status-dot").className = "w-3 h-3 bg-red-500 rounded-full";
      }
    }

    function updateUI(data) {
      // Status badge
      const statusDot = document.getElementById("status-dot");
      const statusText = document.getElementById("status-text");
      
      if (data.status === "online" || data.status === "running") {
        statusDot.className = "w-3 h-3 bg-green-500 rounded-full animate-pulse";
        statusText.textContent = "Online";
      } else if (data.status === "idle") {
        statusDot.className = "w-3 h-3 bg-yellow-500 rounded-full animate-pulse";
        statusText.textContent = "Idle";
      } else {
        statusDot.className = "w-3 h-3 bg-red-500 rounded-full";
        statusText.textContent = data.status || "Unknown";
      }

      // Last update
      if (data.lastUpdate) {
        const date = new Date(data.lastUpdate);
        document.getElementById("last-update").textContent = date.toLocaleString("es-CL");
      }

      // Agent info
      document.getElementById("agent-name").textContent = data.agent || "main";
      document.getElementById("sessions-count").textContent = data.sessions?.length || 0;

      // Uptime
      if (data.uptime) {
        document.getElementById("uptime").textContent = data.uptime;
      }

      // Current task
      const taskEl = document.getElementById("current-task");
      if (data.currentTask) {
        taskEl.innerHTML = `<p class="font-medium">${data.currentTask.name || "Task"}</p>
          <p class="text-sm mt-1">${data.currentTask.description || ""}</p>`;
      } else {
        taskEl.innerHTML = '<p class="text-gray-500">No active task</p>';
      }

      // Jobs
      const jobsEl = document.getElementById("jobs-list");
      if (data.jobs && data.jobs.length > 0) {
        jobsEl.innerHTML = data.jobs.map(job => `
          <div class="flex justify-between items-center p-3 bg-gray-50 dark:bg-gray-700 rounded-lg">
            <div>
              <p class="font-medium">${job.name}</p>
              <p class="text-xs text-gray-500">${job.schedule || "Manual"}</p>
            </div>
            <span class="px-2 py-1 text-xs rounded ${job.enabled ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-500'}">
              ${job.enabled ? "Active" : "Disabled"}
            </span>
          </div>
        `).join("");
      } else {
        jobsEl.innerHTML = '<p class="text-gray-500">No scheduled jobs</p>';
      }

      // Activity log
      const activityEl = document.getElementById("activity-log");
      if (data.activity && data.activity.length > 0) {
        activityEl.innerHTML = data.activity.map(item => `
          <div class="flex gap-3 p-2 rounded hover:bg-gray-50 dark:hover:bg-gray-700">
            <span class="text-gray-400">${item.time || ""}</span>
            <span>${item.message}</span>
          </div>
        `).join("");
      } else {
        activityEl.innerHTML = '<p class="text-gray-500">No recent activity</p>';
      }

      // Errors
      const errorsSection = document.getElementById("errors-section");
      const errorsList = document.getElementById("errors-list");
      if (data.errors && data.errors.length > 0) {
        errorsSection.classList.remove("hidden");
        errorsList.innerHTML = data.errors.map(err => `<p>${err}</p>`).join("");
      } else {
        errorsSection.classList.add("hidden");
      }
    }

    // Initial fetch
    fetchStatus();

    // Auto-refresh every 30 seconds
    setInterval(fetchStatus, 30000);

    // Manual refresh
    document.getElementById("refresh-btn").addEventListener("click", fetchStatus);
  </script>
</Layout>
