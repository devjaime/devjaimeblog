<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📊 Dashboard Jaime - Control Patrimonial</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #3B82F6;
            --success: #10B981;
            --warning: #F59E0B;
            --danger: #EF4444;
        }
        .card {
            @apply bg-white rounded-xl shadow-lg p-6;
        }
        .stat-up { @apply text-green-600; }
        .stat-down { @apply text-red-600; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen">
    <!-- Header -->
    <header class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-6 px-4 shadow-lg">
        <div class="max-w-7xl mx-auto">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold">📊 Dashboard Patrimonial</h1>
                    <p class="text-blue-200">Control de inversiones y propiedades</p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-blue-200">Última actualización</p>
                    <p class="text-xl font-semibold" id="lastUpdate">Cargando...</p>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-7xl mx-auto px-4 py-8">
        <!-- Resumen Ejecutivo -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <!-- Valor Propiedad -->
            <div class="card">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-gray-500 text-sm">Valor Propiedad</span>
                    <span class="text-2xl">🏠</span>
                </div>
                <p class="text-3xl font-bold text-blue-600" id="propertyValue">-</p>
                <p class="text-sm text-gray-500 mt-1">3,500 UF</p>
                <p class="text-sm stat-up mt-2" id="plusvaliaPct">+45%</p>
            </div>

            <!-- UF -->
            <div class="card">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-gray-500 text-sm">UF Hoy</span>
                    <span class="text-2xl">💰</span>
                </div>
                <p class="text-3xl font-bold text-purple-600" id="ufValue">-</p>
                <p class="text-sm text-gray-500 mt-1" id="ufChange">-</p>
            </div>

            <!-- Arriendo -->
            <div class="card">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-gray-500 text-sm">Arriendo Mensual</span>
                    <span class="text-2xl">💵</span>
                </div>
                <p class="text-3xl font-bold text-green-600" id="rentalValue">$500,000</p>
                <p class="text-sm text-gray-500 mt-1">CLP/mes</p>
                <p class="text-sm text-green-500 mt-2" id="rentabilidad">4.45% anual</p>
            </div>

            <!-- Dividistos -->
            <div class="card">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-gray-500 text-sm">Dividendos</span>
                    <span class="text-2xl">📋</span>
                </div>
                <p class="text-3xl font-bold text-orange-600" id="dividendos">4/300</p>
                <p class="text-sm text-gray-500 mt-1">Pagados / Total</p>
                <p class="text-sm text-gray-600 mt-2" id="anosRestantes">~24 años restantes</p>
            </div>
        </section>

        <!-- Gráficos Principales -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <!-- Plusvalía -->
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">📈 Plusvalía Acumulada</h3>
                <div class="h-64">
                    <canvas id="plusvaliaChart"></canvas>
                </div>
            </div>

            <!-- UF History -->
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">💹 Historia UF</h3>
                <div class="h-64">
                    <canvas id="ufChart"></canvas>
                </div>
            </div>
        </section>

        <!-- Progreso Metas -->
        <section class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
            <!-- Meta Segunda Propiedad -->
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">🎯 Meta: Segunda Propiedad</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">target</span>
                        <span class="font-semibold">2028-2029</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-3">
                        <div class="bg-blue-600 h-3 rounded-full" style="width: 25%"></div>
                    </div>
                    <p class="text-sm text-gray-500">Ahorro acumulado vs objetivo</p>
                    <div class="grid grid-cols-2 gap-4 mt-4">
                        <div class="text-center p-3 bg-gray-50 rounded-lg">
                            <p class="text-xs text-gray-500">Ahorrado</p>
                            <p class="text-lg font-bold text-blue-600">$15M</p>
                        </div>
                        <div class="text-center p-3 bg-gray-50 rounded-lg">
                            <p class="text-xs text-gray-500">Objetivo</p>
                            <p class="text-lg font-bold text-gray-600">$60M</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Progreso Crédito -->
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">📊 Progreso Crédito</h3>
                <div class="space-y-4">
                    <div class="flex justify-between items-center">
                        <span class="text-gray-600">Dividendos pagados</span>
                        <span class="font-semibold">4/300</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-3">
                        <div class="bg-green-500 h-3 rounded-full" style="width: 1.3%"></div>
                    </div>
                    <p class="text-sm text-gray-500">1.3% completado</p>
                    <div class="grid grid-cols-2 gap-4 mt-4">
                        <div class="text-center p-3 bg-green-50 rounded-lg">
                            <p class="text-xs text-gray-500">Pagado</p>
                            <p class="text-lg font-bold text-green-600">$800K</p>
                        </div>
                        <div class="text-center p-3 bg-orange-50 rounded-lg">
                            <p class="text-xs text-gray-500">Restante</p>
                            <p class="text-lg font-bold text-orange-600">$59.2M</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Próximos Eventos -->
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">📅 Próximos Eventos</h3>
                <div class="space-y-3">
                    <div class="flex items-center gap-3 p-3 bg-yellow-50 rounded-lg">
                        <span class="text-2xl">🔧</span>
                        <div>
                            <p class="font-semibold text-sm">Mantención Techumbre</p>
                            <p class="text-xs text-gray-500">Junio 2026</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 p-3 bg-blue-50 rounded-lg">
                        <span class="text-2xl">📈</span>
                        <div>
                            <p class="font-semibold text-sm">Revisión Arriendo</p>
                            <p class="text-xs text-gray-500">Diciembre 2026</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 p-3 bg-green-50 rounded-lg">
                        <span class="text-2xl">💰</span>
                        <div>
                            <p class="font-semibold text-sm">Subir Arriendo</p>
                            <p class="text-xs text-gray-500">Enero 2027 → $520K</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Mantenciones -->
        <section class="card mb-8">
            <h3 class="text-lg font-semibold mb-4">🔧 Programa de Mantenciones</h3>
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-4 py-3 text-left">Tarea</th>
                            <th class="px-4 py-3 text-left">Frecuencia</th>
                            <th class="px-4 py-3 text-left">Última</th>
                            <th class="px-4 py-3 text-left">Próxima</th>
                            <th class="px-4 py-3 text-left">Costo Est.</th>
                            <th class="px-4 py-3 text-left">Estado</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y">
                        <tr>
                            <td class="px-4 py-3">Revisión techumbre</td>
                            <td class="px-4 py-3">Anual</td>
                            <td class="px-4 py-3">Jun 2025</td>
                            <td class="px-4 py-3 font-semibold">Jun 2026</td>
                            <td class="px-4 py-3">$80,000</td>
                            <td class="px-4 py-3"><span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-xs">Próxima</span></td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3">Mantención calefacción</td>
                            <td class="px-4 py-3">Anual</td>
                            <td class="px-4 py-3">Abr 2025</td>
                            <td class="px-4 py-3">Abr 2026</td>
                            <td class="px-4 py-3">$45,000</td>
                            <td class="px-4 py-3"><span class="px-2 py-1 bg-yellow-100 text-yellow-800 rounded text-xs">En Breve</span></td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3">Limpieza alcantarillado</td>
                            <td class="px-4 py-3">Bianual</td>
                            <td class="px-4 py-3">Ene 2025</td>
                            <td class="px-4 py-3">Ene 2027</td>
                            <td class="px-4 py-3">$60,000</td>
                            <td class="px-4 py-3"><span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs">OK</span></td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3">Revisión extintores</td>
                            <td class="px-4 py-3">Anual</td>
                            <td class="px-4 py-3">Dic 2025</td>
                            <td class="px-4 py-3">Dic 2026</td>
                            <td class="px-4 py-3">$25,000</td>
                            <td class="px-4 py-3"><span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs">OK</span></td>
                        </tr>
                        <tr>
                            <td class="px-4 py-3">Pintura exterior</td>
                            <td class="px-4 py-3">3 años</td>
                            <td class="px-4 py-3">Ene 2024</td>
                            <td class="px-4 py-3">Ene 2027</td>
                            <td class="px-4 py-3">$500,000</td>
                            <td class="px-4 py-3"><span class="px-2 py-1 bg-gray-100 text-gray-800 rounded text-xs">Planificada</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Notas y Observaciones -->
        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="card">
                <h3 class="text-lg font-semibold mb-4">📝 Observaciones</h3>
                <ul class="space-y-2 text-sm">
                    <li class="flex items-start gap-2">
                        <span class="text-green-500">✓</span>
                        <span>Propiedad en buen estado general</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-green-500">✓</span>
                        <span>Arriendo al día con arrendatario</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-yellow-500">⚠</span>
                        <span>Revisar filtro calefacción antes del invierno</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="text-blue-500">ℹ</span>
                        <span>Plusvalía va muy bien - 45% en 4 meses</span>
                    </li>
                </ul>
            </div>

            <div class="card">
                <h3 class="text-lg font-semibold mb-4">🎯 Notas para Prórxima Revisión</h3>
                <textarea 
                    class="w-full h-32 p-3 border rounded-lg text-sm"
                    placeholder="Agregar notas para la próxima revisión..."
                >- Evaluar aumento de arriendo a $520,000 CLP
- Investigar costo de pintura exterior
- Revisar mercado de arriendos en Coquimbo</textarea>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white py-4 px-4 mt-8">
        <div class="max-w-7xl mx-auto text-center text-sm text-gray-400">
            <p>📊 Dashboard actualizado automáticamente | Datos protegidos</p>
        </div>
    </footer>

    <script>
        // Datos de ejemplo (en producción vendrían de API/archivo)
        const datos = {
            propiedad: {
                nombre: "Casa Coquimbo - Altos del Mirador",
                precioCompra: 2400,
                valorActual: 3500,
                arriendo: 500000,
                mesesArrendada: 4
            },
            uf: {
                actual: 38500,
                historial: [
                    { fecha: '2026-01', valor: 38000 },
                    { fecha: '2026-02', valor: 38200 },
                    { fecha: '2026-03', valor: 38400 },
                    { fecha: '2026-04', valor: 38500 }
                ]
            },
            credito: {
                dividendosPagados: 4,
                dividendosTotales: 300,
               prepagos: 1
            }
        };

        // Actualizar fecha
        document.getElementById('lastUpdate').textContent = new Date().toLocaleString('es-CL');

        // Gráfico Plusvalía
        const plusvaliaCtx = document.getElementById('plusvaliaChart').getContext('2d');
        new Chart(plusvaliaCtx, {
            type: 'line',
            data: {
                labels: ['Dic 2025', 'Ene 2026', 'Feb 2026', 'Mar 2026', 'Abr 2026'],
                datasets: [{
                    label: 'Valor UF',
                    data: [3200, 3300, 3400, 3500, 3500],
                    borderColor: '#3B82F6',
                    backgroundColor: 'rgba(59, 130, 246, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        min: 3000
                    }
                }
            }
        });

        // Gráfico UF
        const ufCtx = document.getElementById('ufChart').getContext('2d');
        new Chart(ufCtx, {
            type: 'bar',
            data: {
                labels: datos.uf.historial.map(h => h.fecha),
                datasets: [{
                    label: 'UF',
                    data: datos.uf.historial.map(h => h.valor),
                    backgroundColor: '#8B5CF6'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false }
                }
            }
        });

        // Animación al cargar
        document.querySelectorAll('.card').forEach((card, i) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => {
                card.style.transition = 'opacity 0.5s, transform 0.5s';
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, i * 100);
        });
    </script>
</body>
</html>
