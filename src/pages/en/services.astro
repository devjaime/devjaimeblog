---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/common/Section.astro";
import { GLOBAL } from "../../lib/variables";
import { ui } from "../../i18n/ui";

const lang = "en";
const t = ui[lang].services;
const services = [
  ["AI agent architecture", "Business-oriented agent flows with tools, memory, evaluation and operational boundaries.", "AI"],
  ["RAG and enterprise knowledge", "Retrieval pipelines, chunking, evaluation and observability for using internal knowledge responsibly.", "RAG"],
  ["Cloud backend and data", "Microservices, Pub/Sub, BigQuery, APIs and reliable jobs underneath AI workflows.", "GCP"],
  ["Applied automation", "n8n, Python and API integrations to reduce manual work while preserving traceability and human control.", "OPS"],
];
const process = [
  ["Diagnosis", "Understand the process, data, constraints, operating cost and risk before proposing AI."],
  ["Architecture", "Design APIs, agents, RAG, queues, monitoring and human checkpoints."],
  ["Implementation", "Build incremental integrations with testing, traceability and real operations in mind."],
  ["Improvement", "Measure quality, latency, cost and feedback to iterate with evidence."],
];
---

<Layout
  title={`${t.eyebrow} • ${GLOBAL.username}`}
  description={t.intro}
  canonical="/en/services"
  type="website"
  lang={lang}
>
  <Section class="services-page">
    <header class="page-hero">
      <p class="eyebrow">{t.eyebrow}</p>
      <h1>{t.title}</h1>
      <p>{t.intro}</p>
    </header>

    <div class="services-grid">
      {services.map(([title, description, icon]) => (
        <article class="service-card">
          <span>{icon}</span>
          <h2>{title}</h2>
          <p>{description}</p>
        </article>
      ))}
    </div>

    <section class="process-section">
      <div>
        <p class="eyebrow">How I work</p>
        <h2>{t.processTitle}</h2>
      </div>
      <ol>
        {process.map(([title, text]) => (
          <li>
            <strong>{title}</strong>
            <p>{text}</p>
          </li>
        ))}
      </ol>
    </section>

    <section class="cta-panel">
      <div>
        <p class="eyebrow">Available for selected collaboration</p>
        <h2>If the workflow is complex, start by making it observable.</h2>
        <p>The best business AI usually starts with good data, clear limits and integrations the team can maintain.</p>
      </div>
      <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer" class="btn-primary">{t.contact}</a>
    </section>
  </Section>
</Layout>

<style>
  .services-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .page-hero {
    max-width: 860px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h1 {
    margin: 0.4rem 0 1rem;
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .page-hero p:not(.eyebrow),
  .service-card p,
  .process-section p,
  .cta-panel p {
    color: var(--on-surface-variant);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .service-card {
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    padding: 1.25rem;
  }

  .service-card span {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 800;
  }

  .service-card h2 {
    margin: 1.4rem 0 0.75rem;
    font-size: 1.18rem;
    letter-spacing: 0;
  }

  .process-section,
  .cta-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 2rem;
    border-top: 1px solid var(--surface-stroke);
    margin-top: 4rem;
    padding-top: 2rem;
  }

  .process-section h2,
  .cta-panel h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  ol {
    display: grid;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
  }

  li {
    counter-increment: step;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.7);
    padding: 1rem;
  }

  li::before {
    content: "0" counter(step);
    display: block;
    margin-bottom: 0.7rem;
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .cta-panel {
    align-items: center;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #0f172a;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .cta-panel h2,
  .cta-panel p {
    color: #f8fafc;
  }

  .cta-panel .eyebrow {
    color: #67e8f9;
  }

  @media (max-width: 980px) {
    .services-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .services-grid,
    .process-section,
    .cta-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
