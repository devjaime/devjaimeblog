---
import Layout from "../../layouts/Layout.astro";
import Section from "../../components/common/Section.astro";
import { GLOBAL } from "../../lib/variables";
import { ui } from "../../i18n/ui";

const lang = "en";
const t = ui[lang].about;
const experience = [
  ["2023 - now", "Backend Engineer, Falabella", "Microservices for accounting and reconciliation flows for IKEA Chile/Colombia with Go, GCP, BigQuery, Pub/Sub, Kubernetes, Grafana and Datadog."],
  ["2024 - 2025", "Founder & CTO, codeIA.cl", "Strategy and implementation of AI, automation, RAG, LangChain and Vercel AI solutions for teams in Chile and LatAm."],
  ["2022 - 2023", "Full-Stack Developer, Continuum HQ", "Clinical applications with React, Node.js, AWS Lambda and hexagonal architecture."],
  ["2021 - 2022", "Backend Engineer, Cornershop by Uber", "APIs and services with Python, Django REST Framework and hexagonal architecture for business domains."],
  ["2006 - 2021", "Software Engineer / Consultant", "Work across retail, healthcare, mining, logistics and telecom with .NET, JavaScript, Python, Angular, mobile and enterprise systems."],
];
---

<Layout
  title={`About ${GLOBAL.fullName} • ${GLOBAL.username}`}
  description={t.intro}
  canonical="/en/about"
  type="website"
  lang={lang}
>
  <Section class="about-page">
    <header class="page-hero">
      <p class="eyebrow">About devjaime</p>
      <h1>{t.title}</h1>
      <p>{t.intro}</p>
    </header>

    <section class="bio-grid">
      <div>
        <h2>{t.focusTitle}</h2>
        <p>{t.focus}</p>
      </div>
      <div class="fact-list">
        <span>Chile / LatAm</span>
        <span>Go · Python · TypeScript</span>
        <span>GCP · BigQuery · Pub/Sub</span>
        <span>LangGraph · LlamaIndex · MCP</span>
      </div>
    </section>

    <section class="timeline">
      <p class="eyebrow">Experience</p>
      <h2>{t.journey}</h2>
      <div class="timeline-list">
        {experience.map(([period, role, text]) => (
          <article>
            <span>{period}</span>
            <h3>{role}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="connect-panel">
      <h2>{t.ctaTitle}</h2>
      <p>{t.ctaText}</p>
      <div>
        <a href="/en/blog" class="btn-primary">Read articles</a>
        <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer" class="btn-secondary">LinkedIn</a>
      </div>
    </section>
  </Section>
</Layout>

<style>
  .about-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .page-hero {
    max-width: 900px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h1 {
    margin: 0.4rem 0 1rem;
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .page-hero p,
  .bio-grid p,
  .timeline p,
  .connect-panel p {
    color: var(--on-surface-variant);
    font-size: 1.05rem;
  }

  .bio-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.55fr);
    gap: 2rem;
    border-top: 1px solid var(--surface-stroke);
    padding-top: 2rem;
  }

  .fact-list {
    display: grid;
    gap: 0.6rem;
  }

  .fact-list span {
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    padding: 0.85rem;
    color: var(--on-surface);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
  }

  .timeline {
    margin-top: 4rem;
  }

  .timeline-list {
    display: grid;
    gap: 0;
    margin-top: 1.5rem;
    border-top: 1px solid var(--surface-stroke);
  }

  .timeline article {
    display: grid;
    grid-template-columns: 150px minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 1.5rem;
    border-bottom: 1px solid var(--surface-stroke);
    padding: 1.25rem 0;
  }

  .timeline article span {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .timeline article h3 {
    font-size: 1.05rem;
    letter-spacing: 0;
  }

  .connect-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    margin-top: 4rem;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .connect-panel div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  @media (max-width: 820px) {
    .bio-grid,
    .timeline article,
    .connect-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
