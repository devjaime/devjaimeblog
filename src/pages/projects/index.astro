---
import { projects } from "../../lib/list";
import Section from "../../components/common/Section.astro";
import ProjectSnippet from "../../components/ProjectSnippet.astro";
import Layout from "../../layouts/Layout.astro";
import { GLOBAL } from "../../lib/variables";
---

<Layout
  title={`${GLOBAL.projectsTitle} • ${GLOBAL.username}`}
  description={GLOBAL.projectLongDescription}
  canonical={`${GLOBAL.rootUrl}/projects`}
  type="website"
>
  <Section class="projects-page">
    <header class="page-hero">
      <p class="eyebrow">Selected work</p>
      <h1>Proyectos donde pruebo, construyo y documento sistemas inteligentes.</h1>
      <p>{GLOBAL.projectShortDescription}</p>
    </header>

    <ul class="project-list">
      {projects.map((project) => (
        <li>
          <ProjectSnippet
            title={project.title}
            description={project.description}
            url={project.filename}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            tags={project.tags ?? []}
          />
        </li>
      ))}
    </ul>
  </Section>
</Layout>

<style>
  .projects-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .page-hero {
    max-width: 860px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h1 {
    margin: 0.4rem 0 1rem;
    font-size: clamp(2.5rem, 6vw, 4.8rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .page-hero p:not(.eyebrow) {
    color: var(--on-surface-variant);
    font-size: 1.08rem;
  }

  .project-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--surface-stroke);
  }
</style>
