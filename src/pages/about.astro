---
import Layout from "../layouts/Layout.astro";
import Section from "../components/common/Section.astro";
import { GLOBAL } from "../lib/variables";

const experience = [
  ["2023 - hoy", "Backend Engineer, Falabella", "Microservicios para flujos contables y conciliación en IKEA Chile/Colombia con Go, GCP, BigQuery, Pub/Sub, Kubernetes, Grafana y Datadog."],
  ["2024 - 2025", "Founder & CTO, codeIA.cl", "Estrategia y construcción de soluciones IA, automatización, RAG, LangChain y Vercel AI para clientes en Chile y LatAm."],
  ["2022 - 2023", "Full-Stack Developer, Continuum HQ", "Aplicaciones clínicas con React, Node.js, AWS Lambda y arquitectura hexagonal."],
  ["2021 - 2022", "Backend Engineer, Cornershop by Uber", "APIs y servicios con Python, Django REST Framework y arquitectura hexagonal para dominios de negocio."],
  ["2006 - 2021", "Software Engineer / Consultant", "Trayectoria en retail, salud, minería, logística y telecomunicaciones con .NET, JavaScript, Python, Angular, mobile y sistemas empresariales."]
];
---

<Layout
  title={`Sobre ${GLOBAL.fullName} • ${GLOBAL.username}`}
  description="Jaime Hernández es backend engineer y AI builder en Chile, especializado en agentes, RAG, microservicios, GCP, Go y Python."
  canonical={`${GLOBAL.rootUrl}/about`}
  type="website"
>
  <Section class="about-page">
    <header class="page-hero">
      <p class="eyebrow">Sobre devjaime</p>
      <h1>Ingeniería backend, IA aplicada y una carrera construida en producción.</h1>
      <p>
        Soy Jaime Hernández, ingeniero de software e IA de Chile. Trabajo en backend para sistemas críticos y construyo proyectos como Vocari para llevar IA útil a problemas reales de LatAm.
      </p>
    </header>

    <section class="bio-grid">
      <div>
        <h2>Mi foco</h2>
        <p>
          Me interesa la IA que se integra con datos, procesos y equipos reales: agentes con herramientas, RAG evaluable, automatizaciones con trazabilidad y backends que soporten operación.
        </p>
      </div>
      <div class="fact-list">
        <span>Chile / LatAm</span>
        <span>Go · Python · TypeScript</span>
        <span>GCP · BigQuery · Pub/Sub</span>
        <span>LangGraph · LlamaIndex · MCP</span>
      </div>
    </section>

    <section class="timeline">
      <p class="eyebrow">Trayectoria</p>
      <h2>De sistemas empresariales a IA de producción.</h2>
      <div class="timeline-list">
        {experience.map(([period, role, text]) => (
          <article>
            <span>{period}</span>
            <h3>{role}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="connect-panel">
      <h2>Estoy construyendo en público.</h2>
      <p>Escribo sobre lo que aprendo implementando backends, agentes, RAG, automatización y productos IA como Vocari.</p>
      <div>
        <a href="/blog" class="btn-primary">Leer artículos</a>
        <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer" class="btn-secondary">LinkedIn</a>
      </div>
    </section>
  </Section>
</Layout>

<style>
  .about-page {
    padding-top: 4rem;
    padding-bottom: 5rem;
  }

  .page-hero {
    max-width: 900px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h1 {
    margin: 0.4rem 0 1rem;
    font-size: clamp(2.7rem, 7vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  h2 {
    font-size: clamp(1.9rem, 4vw, 3rem);
    letter-spacing: 0;
  }

  .page-hero p,
  .bio-grid p,
  .timeline p,
  .connect-panel p {
    color: var(--on-surface-variant);
    font-size: 1.05rem;
  }

  .bio-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 0.55fr);
    gap: 2rem;
    border-top: 1px solid var(--surface-stroke);
    padding-top: 2rem;
  }

  .fact-list {
    display: grid;
    gap: 0.6rem;
  }

  .fact-list span {
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    padding: 0.85rem;
    color: var(--on-surface);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
  }

  .timeline {
    margin-top: 4rem;
  }

  .timeline-list {
    display: grid;
    gap: 0;
    margin-top: 1.5rem;
    border-top: 1px solid var(--surface-stroke);
  }

  .timeline article {
    display: grid;
    grid-template-columns: 150px minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 1.5rem;
    border-bottom: 1px solid var(--surface-stroke);
    padding: 1.25rem 0;
  }

  .timeline article span {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .timeline article h3 {
    font-size: 1.05rem;
    letter-spacing: 0;
  }

  .connect-panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 2rem;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    margin-top: 4rem;
    padding: clamp(1.25rem, 4vw, 2rem);
  }

  .connect-panel div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
  }

  @media (max-width: 820px) {
    .bio-grid,
    .timeline article,
    .connect-panel {
      grid-template-columns: 1fr;
    }
  }
</style>
