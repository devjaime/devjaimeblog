---
import Layout from "../layouts/Layout.astro";
import Section from "../components/common/Section.astro";
import { GLOBAL } from "../lib/variables";
---

<Layout
  title="Contactar • AI Consultant"
  description="Contacta a Jaime Hernández para consultoría en IA, agentes autónomos y automatización inteligente."
  type="website"
>
  <Section class="my-16">
    <div class="max-w-3xl mx-auto">
      
      <!-- Header -->
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Contactar</h1>
        <p class="text-xl zag-muted">¿Interesado en implementar IA en tu negocio? Hablemos.</p>
      </div>

      <!-- Contact Options -->
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        
        <!-- LinkedIn -->
        <a 
          href={GLOBAL.linkedinProfile}
          class="bg-zag-light-bg dark:bg-zag-dark-bg p-8 rounded-lg hover:shadow-lg transition-all hover:-translate-y-1"
          target="_blank"
          rel="noopener"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#0077b5">
                <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.12 19h-3.08v-9h3.08v9zm-1.54-10.29c-.99 0-1.79-.8-1.79-1.79s.8-1.79 1.79-1.79 1.79.8 1.79 1.79-.8 1.79-1.79 1.79zm13.16 10.29h-3.08v-4.89c0-1.16-.02-2.64-1.61-2.64s-1.86 1.26-1.86 2.57v4.96h-3.08v-9h2.96v1.23h.04c.41-.78 1.4-1.6 2.88-1.6 3.08 0 3.65 2.03 3.65 4.66v4.71z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg">LinkedIn</h3>
              <p class="text-sm zag-muted">Conecta profesionalmente</p>
            </div>
          </div>
          <p class="text-sm zag-muted">Mensaje directo para consultas sobre proyectos y colaboración.</p>
        </a>

        <!-- GitHub -->
        <a 
          href={GLOBAL.githubProfile}
          class="bg-zag-light-bg dark:bg-zag-dark-bg p-8 rounded-lg hover:shadow-lg transition-all hover:-translate-y-1"
          target="_blank"
          rel="noopener"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-gray-100 dark:bg-gray-800 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.10-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.10 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg">GitHub</h3>
              <p class="text-sm zag-muted">Explorar código</p>
            </div>
          </div>
          <p class="text-sm zag-muted">Revisa mis proyectos de código abierto y contribuciones.</p>
        </a>

        <!-- Twitter/X -->
        <a 
          href={GLOBAL.twitterProfile}
          class="bg-zag-light-bg dark:bg-zag-dark-bg p-8 rounded-lg hover:shadow-lg transition-all hover:-translate-y-1"
          target="_blank"
          rel="noopener"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-sky-100 dark:bg-sky-900/30 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg">Twitter/X</h3>
              <p class="text-sm zag-muted">Seguimiento rápido</p>
            </div>
          </div>
          <p class="text-sm zag-muted">Para updates y conversación informal.</p>
        </a>

        <!-- Email -->
        <a 
          href="mailto:contacto@jaimehernandez.dev"
          class="bg-zag-light-bg dark:bg-zag-dark-bg p-8 rounded-lg hover:shadow-lg transition-all hover:-translate-y-1"
        >
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-emerald-100 dark:bg-emerald-900/30 rounded-lg flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg">Email</h3>
              <p class="text-sm zag-muted">contacto@jaimehernandez.dev</p>
            </div>
          </div>
          <p class="text-sm zag-muted">Para consultas formales y propuestas de proyecto.</p>
        </a>
      </div>

      <!-- Availability -->
      <div class="bg-emerald-50 dark:bg-emerald-900/20 border border-emerald-200 dark:border-emerald-800 p-6 rounded-lg text-center">
        <div class="flex items-center justify-center gap-2 mb-2">
          <span class="w-3 h-3 bg-emerald-500 rounded-full animate-pulse"></span>
          <span class="font-semibold text-emerald-700 dark:text-emerald-300">Disponible para proyectos</span>
        </div>
        <p class="text-sm zag-muted">
          Especializado en agentes autónomos, automatización IA y arquitecturas LLM para empresas en Latinoamérica.
        </p>
      </div>

    </div>
  </Section>
</Layout>