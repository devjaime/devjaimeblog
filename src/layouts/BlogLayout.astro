---
import Section from "../components/common/Section.astro";
import fs from "node:fs/promises";
import type { ArticleFrontmatter } from "../lib/types";
import { getMarkdownBodyTextLength, processArticleDate } from "../lib/utils";
import { editorialLabels, formatEditorialSource, normalizeEditorial, visibleOperationalMetrics } from "../lib/editorial";
import { GLOBAL } from "../lib/variables";
import type { MarkdownLayoutProps } from "astro";
import Prose from "../components/Prose.astro";
import Layout from "./Layout.astro";

type Props = MarkdownLayoutProps<ArticleFrontmatter>;

const { frontmatter: rawFrontmatter } = Astro.props;
const articlePath = `${process.cwd()}/src/pages${decodeURIComponent(Astro.url.pathname)}.md`;
const articleContent = await fs.readFile(articlePath, "utf8").catch(() => undefined);
const bodyTextLength = getMarkdownBodyTextLength(articleContent);
const isShortAiPost = bodyTextLength >= 40 && bodyTextLength < 300;
const frontmatter = normalizeEditorial({
  ...rawFrontmatter,
  source: isShortAiPost ? "agentic" : rawFrontmatter.source,
});
const lang = frontmatter.lang ?? "es";
const articleDate = processArticleDate(frontmatter.timestamp, lang);
const sourceUrl = new URL(Astro.url.pathname, GLOBAL.rootUrl).href;
const sourceLabel = formatEditorialSource(frontmatter.source, lang);
const reviewLabel = frontmatter.reviewStatus ? editorialLabels[lang][frontmatter.reviewStatus] : undefined;
const visibleMetrics = visibleOperationalMetrics(frontmatter.metrics);
---

<Layout
  title={`${frontmatter.title} • ${GLOBAL.username}`}
  description={frontmatter.description}
  canonical={sourceUrl}
  type="article"
  publishedTime={frontmatter.timestamp}
  modifiedTime={frontmatter.timestamp}
  tags={frontmatter.tags}
  lang={lang}
>
  <Section class="pt-8">
    <header class="article-header">
      <div class="editorial-row" aria-label={lang === "en" ? "Editorial metadata" : "Metadatos editoriales"}>
        <span class:list={["source-badge", frontmatter.source === "agentic" && "source-badge-agentic"]}>{sourceLabel}</span>
        {frontmatter.type && <span>{frontmatter.type}</span>}
        {reviewLabel && <span>{reviewLabel}</span>}
      </div>
      <h1
        class="text-3xl sm:text-5xl leading-tight mb-6"
      >
        {frontmatter.title}
      </h1>
      <div class="flex justify-between items-center text-sm" style="color: var(--on-surface-variant);">
        <span class="label-caps">{articleDate}</span>
        <span class="label-caps">{frontmatter.time} min read</span>
      </div>
      {frontmatter.source === "agentic" && (
        <p class="agentic-note">
          {lang === "en"
            ? "Agentic entry: generated from a technical workflow and separated from manually edited essays. Metrics are shown only when present in source metadata."
            : "Entrada agentica: generada desde un flujo técnico y separada de los ensayos editados manualmente. Las métricas solo se muestran cuando existen en la metadata fuente."}
        </p>
      )}
      {visibleMetrics.length > 0 && (
        <dl class="metrics-panel">
          {visibleMetrics.map(([key, value]) => (
            <>
              <dt>{key}</dt>
              <dd>{String(value)}</dd>
            </>
          ))}
        </dl>
      )}
    </header>
    
    <!-- Article content -->
    <!--
      Article content must remain visible without JavaScript. Previously this used
      `animate-on-scroll`, whose base CSS sets opacity to 0 until the client-side
      observer runs. When that observer did not initialize, every post rendered
      an empty body.
    -->
    <article>
      <Prose>
        <slot />
      </Prose>
    </article>
    
    <!-- Author signature -->
    <footer class="pt-8 mt-8 border-t" style="border-color: var(--surface-stroke);">
      <p class="flex items-center gap-3" style="color: var(--on-surface-variant);">
        <span class="label-caps">~{GLOBAL.username}</span>
        <span 
          class="h-px flex-1 max-w-[60px]"
          style="background: linear-gradient(90deg, var(--neural-violet), transparent);"
        ></span>
      </p>
    </footer>
  </Section>
</Layout>

<style>
  .article-header {
    border: 1px solid #242424;
    border-radius: 12px;
    background: var(--editorial-ink);
    margin-bottom: 3rem;
    padding: clamp(1.5rem, 5vw, 3.5rem);
    color: var(--editorial-paper);
  }

  .article-header h1 {
    max-width: 980px;
    color: var(--editorial-paper);
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(3rem, 7vw, 6.25rem);
    font-weight: 400;
    line-height: 0.93;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .editorial-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-bottom: 1rem;
    color: var(--editorial-yellow);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .editorial-row span {
    border: 1px solid #393939;
    border-radius: 999px;
    background: #151515;
    padding: 0.3rem 0.55rem;
  }

  .source-badge {
    color: var(--editorial-yellow);
  }

  .source-badge-agentic {
    color: var(--editorial-violet);
    border-color: rgba(185, 161, 255, 0.35);
    background: rgba(185, 161, 255, 0.08);
  }

  .agentic-note {
    border-left: 3px solid var(--editorial-violet);
    margin-top: 1.25rem;
    padding-left: 1rem;
    color: #bdbdb7;
  }

  .metrics-panel {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .metrics-panel dt,
  .metrics-panel dd {
    border: 1px solid #393939;
    background: #151515;
    margin: 0;
    padding: 0.55rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
  }

  .metrics-panel dt {
    color: #a5a5a0;
  }

  .metrics-panel dd {
    color: var(--editorial-yellow);
    font-weight: 800;
  }

  @media (max-width: 720px) {
    .metrics-panel {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
