---
import Section from "../components/common/Section.astro";
import type { ArticleFrontmatter } from "../lib/types";
import {
  getShortDescription,
  processArticleDate,
  generateSourceUrl,
} from "../lib/utils";
import { GLOBAL } from "../lib/variables";
import type { MarkdownLayoutProps } from "astro";
import Prose from "../components/Prose.astro";
import Layout from "./Layout.astro";

type Props = MarkdownLayoutProps<ArticleFrontmatter>;

const { frontmatter } = Astro.props;
const shortDescription = getShortDescription(frontmatter.description);
const articleDate = processArticleDate(frontmatter.timestamp);
const sourceUrl = generateSourceUrl(frontmatter.filename, "blog");
---

<Layout>
  <Fragment slot="head">
    <title>{frontmatter.title} • {GLOBAL.username}</title>
    <meta name="description" content={frontmatter.description} />
    <meta property="og:title" content={`${frontmatter.title} • ${GLOBAL.username}`} />
    <meta property="og:description" content={shortDescription} />
    <meta property="og:image" content={`${GLOBAL.rootUrl}/${GLOBAL.profileImage}`} />
    <meta property="og:url" content={frontmatter.url} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${frontmatter.title} • ${GLOBAL.username}`} />
    <meta name="twitter:description" content={shortDescription} />
    <meta name="twitter:image" content={`${GLOBAL.rootUrl}/${GLOBAL.profileImage}`} />
    <meta http-equiv="content-language" content="es" />
    <meta name="language" content="Spanish" />
    <link rel="canonical" href={sourceUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": frontmatter.title,
      "description": frontmatter.description,
      "datePublished": frontmatter.publishDate,
      "author": {
        "@type": "Person",
        "name": frontmatter.author?.name || "Jaime Hernández",
        "url": frontmatter.author?.url || "https://jaimehernandez.dev"
      },
      "publisher": {
        "@type": "Person",
        "name": "Jaime Hernández",
        "url": "https://jaimehernandez.dev"
      },
      "url": sourceUrl,
      "image": `${GLOBAL.rootUrl}/${GLOBAL.profileImage}`
    })} />
  </Fragment>
  <Section class="pt-8">
    <!-- Article header with glassmorphism -->
    <header class="glass-card p-8 mb-12 animate-on-scroll">
      <h1
        class="text-3xl sm:text-4xl leading-normal sm:leading-normal mb-6"
        style="font-family: 'Manrope', system-ui, sans-serif; color: var(--on-surface);"
      >
        {frontmatter.title}
      </h1>
      <div class="flex justify-between items-center text-sm" style="color: var(--on-surface-variant);">
        <span class="label-caps">{articleDate}</span>
        <span class="label-caps">{frontmatter.time} min read</span>
      </div>
      <!-- Gradient accent line -->
      <div 
        class="h-0.5 w-full mt-6"
        style="background: linear-gradient(90deg, var(--electric-blue), var(--neural-violet), transparent);"
      ></div>
    </header>
    
    <!-- Article content -->
    <article class="animate-on-scroll stagger-2">
      <Prose>
        <slot />
      </Prose>
    </article>
    
    <!-- Author signature -->
    <footer class="pt-8 mt-8 border-t" style="border-color: var(--surface-stroke);">
      <p class="flex items-center gap-3" style="color: var(--on-surface-variant);">
        <span class="label-caps">~{GLOBAL.username}</span>
        <span 
          class="h-px flex-1 max-w-[60px]"
          style="background: linear-gradient(90deg, var(--neural-violet), transparent);"
        ></span>
      </p>
    </footer>
  </Section>
</Layout>