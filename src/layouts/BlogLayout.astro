---
import Section from "../components/common/Section.astro";
import type { ArticleFrontmatter } from "../lib/types";
import {
  processArticleDate,
  generateSourceUrl,
} from "../lib/utils";
import { GLOBAL } from "../lib/variables";
import type { MarkdownLayoutProps } from "astro";
import Prose from "../components/Prose.astro";
import Layout from "./Layout.astro";

type Props = MarkdownLayoutProps<ArticleFrontmatter>;

const { frontmatter } = Astro.props;
const articleDate = processArticleDate(frontmatter.timestamp);
const sourceUrl = generateSourceUrl(frontmatter.filename, "blog");
---

<Layout
  title={`${frontmatter.title} • ${GLOBAL.username}`}
  description={frontmatter.description}
  canonical={sourceUrl}
  type="article"
  publishedTime={frontmatter.timestamp}
  modifiedTime={frontmatter.timestamp}
  tags={frontmatter.tags}
>
  <Section class="pt-8">
    <header class="article-header">
      <h1
        class="text-3xl sm:text-5xl leading-tight mb-6"
        style="font-family: 'Manrope', system-ui, sans-serif; color: var(--on-surface); letter-spacing: 0;"
      >
        {frontmatter.title}
      </h1>
      <div class="flex justify-between items-center text-sm" style="color: var(--on-surface-variant);">
        <span class="label-caps">{articleDate}</span>
        <span class="label-caps">{frontmatter.time} min read</span>
      </div>
    </header>
    
    <!-- Article content -->
    <article class="animate-on-scroll stagger-2">
      <Prose>
        <slot />
      </Prose>
    </article>
    
    <!-- Author signature -->
    <footer class="pt-8 mt-8 border-t" style="border-color: var(--surface-stroke);">
      <p class="flex items-center gap-3" style="color: var(--on-surface-variant);">
        <span class="label-caps">~{GLOBAL.username}</span>
        <span 
          class="h-px flex-1 max-w-[60px]"
          style="background: linear-gradient(90deg, var(--neural-violet), transparent);"
        ></span>
      </p>
    </footer>
  </Section>
</Layout>

<style>
  .article-header {
    border-bottom: 1px solid var(--surface-stroke);
    margin-bottom: 3rem;
    padding: 3rem 0 2rem;
  }
</style>
