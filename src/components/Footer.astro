---
import { GLOBAL } from "../lib/variables";
import { routes, ui, type Locale } from "../i18n/ui";

const year = new Date().getFullYear();
const { lang = "es" } = Astro.props as { lang?: Locale };
const footerText =
  lang === "en"
    ? "Building intelligent systems from Chile for real-world teams and workflows."
    : "Construyendo sistemas inteligentes desde Chile para equipos y flujos reales.";
---

<footer class="site-footer">
  <div class="footer-inner">
    <div>
      <strong>devjaime</strong>
      <p>{footerText}</p>
    </div>
    <nav aria-label={lang === "en" ? "Social links" : "Enlaces sociales"}>
      <a href={GLOBAL.githubProfile} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={GLOBAL.youtubeChannel} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href={routes[lang].contact}>{ui[lang].nav.contact}</a>
    </nav>
  </div>
  <p class="copyright">&copy; {year} Jaime Hernández · AI & Software Engineering</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--surface-stroke);
    margin-top: 5rem;
    padding: 2rem 1.25rem;
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  strong {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.15rem;
  }

  p {
    max-width: 520px;
    color: var(--on-surface-variant);
    margin-top: 0.35rem;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-content: start;
  }

  a {
    color: var(--on-surface);
    font-weight: 700;
    text-decoration-color: var(--outline);
  }

  .copyright {
    max-width: 72rem;
    margin: 2rem auto 0;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
  }

  @media (max-width: 720px) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>
