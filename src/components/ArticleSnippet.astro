---
import { processArticleDate } from "../lib/utils";
import { editorialLabels, formatEditorialSource, hasOperationalMetrics } from "../lib/editorial";
import type { EditorialMetrics, EditorialSource, EditorialType, ReviewStatus } from "../lib/types";

export type Props = {
  title: string;
  description: string;
  url: string;
  duration?: string;
  timestamp?: string;
  tags?: string[];
  lang?: "es" | "en";
  type?: EditorialType;
  source?: EditorialSource;
  reviewStatus?: ReviewStatus;
  metrics?: EditorialMetrics;
};

const { title, description, url, duration, timestamp, tags, lang = "es", type, source, reviewStatus, metrics } = Astro.props;
const sourceLabel = formatEditorialSource(source, lang);
const statusLabel = reviewStatus ? editorialLabels[lang][reviewStatus] : undefined;
const hasMetrics = hasOperationalMetrics(metrics);
---

<article class:list={["article-snippet-card", source === "human" && "article-snippet-card-human", source === "agentic" && "article-snippet-card-agentic", source === "hybrid" && "article-snippet-card-hybrid"]}>
  <div>
    <div class="article-badges">
      <span class:list={["source-badge", source === "agentic" && "source-badge-agentic"]}>{sourceLabel}</span>
      {type && <span>{type}</span>}
      {statusLabel && <span>{statusLabel}</span>}
    </div>
    {tags && tags.length > 0 && <p class="article-category">{tags[0]}</p>}
    <a href={url} class="article-snippet-title">{title}</a>
  </div>
  <p class="article-snippet-description">{description}</p>
  {hasMetrics && (
    <dl class="metric-row" aria-label={lang === "en" ? "Available metrics" : "Métricas disponibles"}>
      {metrics?.commits !== undefined && <><dt>Commits</dt><dd>{metrics.commits}</dd></>}
      {metrics?.filesChanged !== undefined && <><dt>Files</dt><dd>{metrics.filesChanged}</dd></>}
      {metrics?.buildStatus && <><dt>Build</dt><dd>{metrics.buildStatus}</dd></>}
      {metrics?.lighthouseSEO !== undefined && <><dt>SEO</dt><dd>{metrics.lighthouseSEO}</dd></>}
    </dl>
  )}
  {source === "agentic" && !hasMetrics && (
    <p class="metric-empty">{editorialLabels[lang].noVerifiedMetrics}</p>
  )}
  <div class="article-snippet-meta">
    {timestamp && <span>{processArticleDate(timestamp, lang)}</span>}
    {duration && <span>{duration}</span>}
  </div>
</article>

<style>
  .article-snippet-card {
    height: 100%;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.18s ease, background 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
  }

  .article-snippet-card:hover {
    border-color: rgba(37, 99, 235, 0.42);
    background: #ffffff;
    box-shadow: 0 10px 24px rgba(23, 23, 23, 0.08);
    transform: translateY(-3px);
  }

  .article-snippet-card-human {
    border-color: rgba(15, 118, 110, 0.2);
  }

  .article-snippet-card-agentic {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.82), rgba(245, 248, 255, 0.72));
    border-color: rgba(37, 99, 235, 0.22);
  }

  .article-snippet-card-hybrid {
    border-color: rgba(15, 118, 110, 0.24);
  }

  .article-category,
  .article-snippet-meta,
  .article-badges,
  .metric-row {
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .article-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.7rem;
  }

  .article-badges span {
    border: 1px solid var(--surface-stroke);
    border-radius: 999px;
    background: #fff;
    padding: 0.25rem 0.45rem;
  }

  .source-badge {
    color: var(--secondary);
  }

  .source-badge::before {
    content: "";
    display: inline-block;
    width: 0.42rem;
    height: 0.42rem;
    margin-right: 0.35rem;
    border-radius: 999px;
    background: currentColor;
    vertical-align: 0.04rem;
  }

  .source-badge-agentic {
    color: var(--primary);
    background: rgba(37, 99, 235, 0.06);
    border-color: rgba(37, 99, 235, 0.18);
  }

  .source-badge-agentic::before {
    animation: ai-signal 1.8s ease-in-out infinite;
  }

  @keyframes ai-signal {
    50% {
      box-shadow: 0 0 0 0.28rem rgba(37, 99, 235, 0);
      opacity: 0.7;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-snippet-card {
      transition: none;
    }

    .article-snippet-card:hover {
      transform: none;
    }

    .source-badge-agentic::before {
      animation: none;
    }
  }

  .article-snippet-title {
    display: block;
    color: var(--on-surface);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.25;
    text-decoration: none;
  }

  .article-snippet-title:hover {
    color: var(--primary);
  }

  .article-snippet-description {
    color: var(--on-surface-variant);
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }

  .article-snippet-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--surface-stroke);
  }

  .metric-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.35rem 0.7rem;
    border-top: 1px solid var(--surface-stroke);
    padding-top: 0.75rem;
  }

  .metric-row dt {
    color: var(--on-surface-variant);
  }

  .metric-row dd {
    color: var(--on-surface);
    margin: 0;
    text-align: right;
  }

  .metric-empty {
    border-top: 1px solid var(--surface-stroke);
    padding-top: 0.75rem;
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    text-transform: uppercase;
  }
</style>
