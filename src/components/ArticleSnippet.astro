---
import { processArticleDate } from "../lib/utils";

export type Props = {
  title: string;
  description: string;
  url: string;
  duration?: string;
  timestamp?: string;
  tags?: string[];
};

const { title, description, url, duration, timestamp, tags } = Astro.props;
---

<article class="article-snippet-card">
  <div>
    {tags && tags.length > 0 && <p class="article-category">{tags[0]}</p>}
    <a href={url} class="article-snippet-title">{title}</a>
  </div>
  <p class="article-snippet-description">{description}</p>
  <div class="article-snippet-meta">
    {timestamp && <span>{processArticleDate(timestamp)}</span>}
    {duration && <span>{duration}</span>}
  </div>
</article>

<style>
  .article-snippet-card {
    height: 100%;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.72);
    padding: 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.18s ease, background 0.18s ease;
  }

  .article-snippet-card:hover {
    border-color: rgba(37, 99, 235, 0.42);
    background: #ffffff;
  }

  .article-category,
  .article-snippet-meta {
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  .article-snippet-title {
    display: block;
    color: var(--on-surface);
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.08rem;
    font-weight: 800;
    line-height: 1.25;
    text-decoration: none;
  }

  .article-snippet-title:hover {
    color: var(--primary);
  }

  .article-snippet-description {
    color: var(--on-surface-variant);
    font-size: 0.95rem;
    line-height: 1.6;
    flex: 1;
  }

  .article-snippet-meta {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--surface-stroke);
  }
</style>
