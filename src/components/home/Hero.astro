---
import { GLOBAL } from "../../lib/variables";

const typingTexts = [
  "AI Agent Architect",
  "LangChain & LangGraph Expert",
  "RAG Systems Designer",
  "Automation Engineer",
  "GCP & Python Developer"
];

const stats = [
  { value: "8+", label: "Years Experience" },
  { value: "50+", label: "Projects Delivered" },
  { value: "20+", label: "AI Agents Built" },
  { value: "99.9%", label: "Uptime SLA" }
];

const primarySkills = ["Go", "Python", "LangChain", "LangGraph", "GCP", "Docker", "Kubernetes", "PostgreSQL"];
const secondarySkills = ["CrewAI", "Claude API", "Ollama", "MCP", "RAG", "FastAPI", "n8n", "Redis"];
---

<section class="hero-section">
  <div class="container mx-auto px-4 py-16 max-w-7xl">
    <div class="lg:flex flex-col items-center gap-12">
      <div class="content-container text-center flex-1 max-w-4xl">
        
        <!-- Name -->
        <h1 class="hero-title text-4xl xl:text-5xl 2xl:text-6xl font-display font-bold mb-4">
          {GLOBAL.username}
        </h1>

        <!-- Typing Animation Role -->
        <div class="typewriter-container mb-6 h-12 flex items-center justify-center">
          <span class="typewriter-text text-xl xl:text-2xl 2xl:text-3xl font-mono font-medium" style="color: var(--electric-blue);"></span>
          <span class="typewriter-cursor" style="border-right: 2px solid var(--electric-blue);"></span>
        </div>

        <!-- Tagline -->
        <p class="hero-description text-lg xl:text-xl 2xl:text-2xl mb-8 leading-relaxed" style="color: var(--on-surface-variant);">
          {GLOBAL.heroDescription}
        </p>

        <!-- Stats Row -->
        <div class="stats-row grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
          {stats.map((stat) => (
            <div class="stat-card">
              <span class="stat-value text-2xl xl:text-3xl font-bold gradient-text">{stat.value}</span>
              <span class="stat-label text-xs xl:text-sm mt-1" style="color: var(--on-surface-variant);">{stat.label}</span>
            </div>
          ))}
        </div>

        <!-- Skills Pills - Primary -->
        <div class="skills-section mb-6">
          <p class="skills-label text-xs font-semibold mb-3 uppercase tracking-wider" style="color: var(--on-surface-variant);">Tech Stack</p>
          <div class="skills-pills flex flex-wrap gap-2 justify-center">
            {primarySkills.map((skill, index) => (
              <span class="skill-pill" style={`animation-delay: ${index * 0.05}s`}>{skill}</span>
            ))}
          </div>
        </div>

        <!-- Skills Pills - Secondary (AI Focus) -->
        <div class="skills-section mb-10">
          <div class="skills-pills flex flex-wrap gap-2 justify-center">
            {secondarySkills.map((skill, index) => (
              <span class="skill-pill violet" style={`animation-delay: ${(index + primarySkills.length) * 0.05}s`}>{skill}</span>
            ))}
          </div>
        </div>

        <!-- Action buttons -->
        <div class="hero-buttons flex flex-wrap gap-4 justify-center">
          <a 
            href={GLOBAL.linkedinProfile} 
            class="btn-primary flex items-center gap-2 text-base xl:text-lg px-6 py-3"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn Profile"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.76 0 5-2.24 5-5v-14c0-2.76-2.24-5-5-5zm-11.12 19h-3.08v-9h3.08v9zm-1.54-10.29c-.99 0-1.79-.8-1.79-1.79s.8-1.79 1.79-1.79 1.79.8 1.79 1.79-.8 1.79-1.79 1.79zm13.16 10.29h-3.08v-4.89c0-1.16-.02-2.64-1.61-2.64s-1.86 1.26-1.86 2.57v4.96h-3.08v-9h2.96v1.23h.04c.41-.78 1.4-1.6 2.88-1.6 3.08 0 3.65 2.03 3.65 4.66v4.71z"/>
            </svg>
            {GLOBAL.connectButton}
          </a>
          
          <a 
            href={GLOBAL.githubProfile} 
            class="border-2 flex items-center gap-2 text-base xl:text-lg px-6 py-3 rounded-lg font-medium hover:text-white transition-all"
            style="border-color: var(--electric-blue); color: var(--electric-blue);"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub Repository"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.10-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.10 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/>
            </svg>
            {GLOBAL.viewCodeButton}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 85vh;
    display: flex;
    align-items: center;
  }

  .hero-title {
    margin-bottom: 0.5rem;
  }

  .typewriter-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
  }

  .typewriter-text {
    overflow: hidden;
    white-space: nowrap;
    border-right: none;
    animation: typewriter-cursor 1s step-end infinite;
  }

  .typewriter-cursor {
    display: inline-block;
    width: 3px;
    height: 1.5em;
    margin-left: 4px;
    animation: blink 1s step-end infinite;
    vertical-align: text-bottom;
  }

  .stats-row {
    max-width: 600px;
    margin: 0 auto;
  }

  .stat-value {
    line-height: 1.2;
  }

  .skills-section {
    width: 100%;
  }

  .skills-label {
    font-family: 'JetBrains Mono', monospace;
  }

  .skill-pill {
    opacity: 0;
    animation: fadeSlideIn 0.4s ease forwards;
  }

  @keyframes fadeSlideIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1024px) {
    .hero-section {
      min-height: auto;
      padding: 3rem 0;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .typewriter-text {
      font-size: 1.125rem;
    }
  }
</style>

<script define:vars={{ typingTexts }}>
  const textElement = document.querySelector('.typewriter-text');
  let textIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typeSpeed = 100;

  function type() {
    const currentText = typingTexts[textIndex];
    
    if (isDeleting) {
      textElement.textContent = currentText.substring(0, charIndex - 1);
      charIndex--;
      typeSpeed = 50;
    } else {
      textElement.textContent = currentText.substring(0, charIndex + 1);
      charIndex++;
      typeSpeed = 100;
    }

    if (!isDeleting && charIndex === currentText.length) {
      isDeleting = true;
      typeSpeed = 2000;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      textIndex = (textIndex + 1) % typingTexts.length;
      typeSpeed = 500;
    }

    setTimeout(type, typeSpeed);
  }

  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(type, 500);
  });
</script>
