---
import { routes, ui, type Locale } from "../../i18n/ui";
import { GLOBAL } from "../../lib/variables";

const { lang = "es" } = Astro.props as { lang?: Locale };
const t = ui[lang];
const systemNodes = ["Agent", "Retriever", "Vector DB", "API", "BigQuery", "Cloud Run"];
---

<section class="hero-shell">
  <div class="hero-copy">
    <p class="eyebrow">{t.hero.eyebrow}</p>
    <h1 aria-label={t.hero.title}>
      {lang === "es" ? (
        <>Construyo sistemas <span class="accent-yellow">inteligentes</span> que funcionan <span class="accent-violet">en producción.</span></>
      ) : (
        <>I build <span class="accent-yellow">intelligent systems</span> that work <span class="accent-violet">in production.</span></>
      )}
    </h1>
    <p class="hero-lead">{t.hero.subtitle}</p>

    <div class="hero-actions" aria-label="Acciones principales">
      <a href={routes[lang].blog} class="btn-primary">{t.hero.ctas.articles}</a>
      <a href={routes[lang].videos} class="btn-secondary">{t.hero.ctas.videos}</a>
      <a href={routes[lang].projects} class="btn-secondary">{t.hero.ctas.projects}</a>
      <a href={routes[lang].contact} class="btn-quiet">{t.hero.ctas.contact}</a>
    </div>

    <nav class="hero-links" aria-label="Enlaces de devjaime">
      <a href={GLOBAL.githubProfile} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={GLOBAL.youtubeChannel} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href={routes[lang].blog}>Blog</a>
      <a href={routes[lang].contact}>{t.nav.contact}</a>
    </nav>
  </div>

  <div class="system-board" aria-label="Mapa visual de sistemas que construye devjaime">
    <div class="board-header">
      <span>{t.hero.boardTitle}</span>
      <span>{t.hero.boardRegion}</span>
    </div>
    <div class="board-grid">
      {systemNodes.map((node, index) => (
        <div class:list={["node-card", index === 0 && "node-card-featured"]}>
          <span class="node-index">0{index + 1}</span>
          <strong>{node}</strong>
        </div>
      ))}
    </div>
    <div class="terminal-card">
      <span>{t.hero.terminal}</span>
      <span>{t.hero.checks}</span>
    </div>
  </div>
</section>

<div class="authority-strip" aria-label="Pilares técnicos">
  {t.authority.map((area) => <span>{area}</span>)}
</div>

<style>
  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding: clamp(3rem, 8vw, 6rem) clamp(1.25rem, 4vw, 3.5rem);
    margin-top: clamp(1.5rem, 4vw, 3rem);
    border-radius: 12px;
    background: var(--editorial-ink);
    color: var(--editorial-paper);
    overflow: hidden;
  }

  .hero-copy,
  .system-board {
    min-width: 0;
  }

  .eyebrow {
    margin-bottom: 1rem;
    color: var(--editorial-yellow);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  h1 {
    max-width: 820px;
    color: var(--editorial-paper);
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(3.4rem, 8vw, 6.6rem);
    font-weight: 400;
    line-height: 0.88;
    letter-spacing: -0.045em;
    text-wrap: balance;
    overflow-wrap: anywhere;
  }

  .accent-yellow { color: var(--editorial-yellow); }
  .accent-violet { color: var(--editorial-violet); }

  .hero-lead {
    max-width: 720px;
    margin-top: 1.5rem;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    color: #c8c8c2;
  }

  .hero-actions,
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
    align-items: center;
  }

  .hero-links {
    margin-top: 1.35rem;
    gap: 1rem;
    font-size: 0.95rem;
  }

  .hero-links a,
  .btn-quiet {
    color: var(--editorial-paper);
    text-decoration: underline;
    text-decoration-color: #666;
    text-underline-offset: 0.3em;
  }

  .system-board {
    position: relative;
    border: 1px solid #343434;
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(20, 20, 20, 0.96), rgba(10, 10, 10, 0.92)),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(185, 161, 255, 0.08) 40px);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.35);
    padding: 1rem;
    overflow: hidden;
  }

  .system-board::after {
    content: "";
    position: absolute;
    inset: 18% 12%;
    border: 1px solid rgba(185, 161, 255, 0.4);
    transform: rotate(-8deg);
    pointer-events: none;
  }

  .board-header,
  .terminal-card {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #aaa;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
  }

  .board-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 1rem 0;
  }

  .node-card {
    min-height: 92px;
    border: 1px solid #343434;
    border-radius: 8px;
    background: rgba(20, 20, 20, 0.9);
    color: var(--editorial-paper);
    padding: 0.9rem;
  }

  .node-card-featured {
    background: var(--editorial-yellow);
    color: var(--editorial-ink);
  }

  .node-index {
    display: block;
    margin-bottom: 1.4rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    opacity: 0.7;
  }

  .terminal-card {
    position: relative;
    z-index: 1;
    flex-direction: column;
    border: 1px solid #343434;
    border-radius: 8px;
    background: #111;
    color: var(--editorial-violet);
    padding: 1rem;
  }

  .terminal-card span {
    overflow-wrap: anywhere;
  }

  .authority-strip {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    border-block: 1px solid var(--surface-stroke);
    margin-bottom: 3rem;
  }

  .authority-strip span {
    padding: 1rem 0.75rem;
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    text-align: center;
  }

  @media (max-width: 860px) {
    .hero-shell {
      grid-template-columns: 1fr;
      padding-top: 3rem;
      padding-inline: 1.25rem;
    }

    .authority-strip {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 520px) {
    .hero-shell {
      display: block;
      width: 100%;
      max-width: 100%;
    }

    h1 {
      font-size: clamp(2.65rem, 12vw, 3.15rem);
      text-wrap: wrap;
    }

    .board-grid,
    .authority-strip {
      grid-template-columns: 1fr;
    }

    .system-board {
      width: 100%;
      max-width: 100%;
      margin-top: 2.5rem;
      padding: 0.8rem;
    }
  }
</style>
