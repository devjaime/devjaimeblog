---
import { GLOBAL } from "../../lib/variables";

const focusAreas = ["Backend Engineering", "AI Agents", "RAG Systems", "Cloud & Data", "Developer Tools"];
const systemNodes = ["Vocari", "Agentes", "RAG", "GCP", "Go APIs", "BigQuery"];
---

<section class="hero-shell">
  <div class="hero-copy">
    <p class="eyebrow">devjaime · AI & Software Engineering from Chile</p>
    <h1>Construyo sistemas inteligentes que escalan.</h1>
    <p class="hero-lead">{GLOBAL.heroDescription}</p>

    <div class="hero-actions" aria-label="Acciones principales">
      <a href="/blog" class="btn-primary">Leer artículos</a>
      <a href="/projects" class="btn-secondary">Ver proyectos</a>
      <a href="/contact" class="btn-quiet">Trabajemos juntos</a>
    </div>

    <nav class="hero-links" aria-label="Enlaces de devjaime">
      <a href={GLOBAL.githubProfile} target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href={GLOBAL.linkedinProfile} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href={GLOBAL.youtubeChannel} target="_blank" rel="noopener noreferrer">YouTube</a>
      <a href="/blog">Blog</a>
      <a href="/contact">Contacto</a>
    </nav>
  </div>

  <div class="system-board" aria-label="Mapa visual de sistemas que construye devjaime">
    <div class="board-header">
      <span>Production AI System</span>
      <span>Chile / LatAm</span>
    </div>
    <div class="board-grid">
      {systemNodes.map((node, index) => (
        <div class:list={["node-card", index === 0 && "node-card-featured"]}>
          <span class="node-index">0{index + 1}</span>
          <strong>{node}</strong>
        </div>
      ))}
    </div>
    <div class="terminal-card">
      <span>$ deploy ai-workflow --with-observability</span>
      <span>checks: retrieval, latency, cost, human-review</span>
    </div>
  </div>
</section>

<div class="authority-strip" aria-label="Pilares técnicos">
  {focusAreas.map((area) => <span>{area}</span>)}
</div>

<style>
  .hero-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding: clamp(4rem, 10vw, 7rem) 0 2rem;
  }

  .eyebrow {
    margin-bottom: 1rem;
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h1 {
    max-width: 820px;
    font-size: clamp(3rem, 8vw, 5.8rem);
    line-height: 0.98;
    letter-spacing: 0;
  }

  .hero-lead {
    max-width: 720px;
    margin-top: 1.5rem;
    font-size: clamp(1.08rem, 2vw, 1.35rem);
    color: var(--on-surface-variant);
  }

  .hero-actions,
  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
    align-items: center;
  }

  .hero-links {
    margin-top: 1.35rem;
    gap: 1rem;
    font-size: 0.95rem;
  }

  .hero-links a,
  .btn-quiet {
    color: var(--on-surface);
    text-decoration: underline;
    text-decoration-color: var(--outline);
    text-underline-offset: 0.3em;
  }

  .system-board {
    position: relative;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.48)),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(37, 99, 235, 0.05) 40px),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(15, 23, 42, 0.04) 40px);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.08);
    padding: 1rem;
    overflow: hidden;
  }

  .system-board::after {
    content: "";
    position: absolute;
    inset: 18% 12%;
    border: 1px solid rgba(6, 182, 212, 0.28);
    transform: rotate(-8deg);
    pointer-events: none;
  }

  .board-header,
  .terminal-card {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
  }

  .board-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    margin: 1rem 0;
  }

  .node-card {
    min-height: 92px;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: rgba(250, 250, 247, 0.86);
    padding: 0.9rem;
  }

  .node-card-featured {
    background: var(--primary);
    color: var(--on-primary);
  }

  .node-index {
    display: block;
    margin-bottom: 1.4rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
    opacity: 0.7;
  }

  .terminal-card {
    position: relative;
    z-index: 1;
    flex-direction: column;
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 8px;
    background: #0f172a;
    color: #dbeafe;
    padding: 1rem;
  }

  .authority-strip {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    border-block: 1px solid var(--surface-stroke);
    margin-bottom: 3rem;
  }

  .authority-strip span {
    padding: 1rem 0.75rem;
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.78rem;
    text-align: center;
  }

  @media (max-width: 860px) {
    .hero-shell {
      grid-template-columns: 1fr;
      padding-top: 3rem;
    }

    .authority-strip {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 520px) {
    h1 {
      font-size: 3rem;
    }

    .board-grid,
    .authority-strip {
      grid-template-columns: 1fr;
    }

    .system-board {
      padding: 0.8rem;
    }
  }
</style>
