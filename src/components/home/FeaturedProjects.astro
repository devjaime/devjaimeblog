---
import type { ProjectFrontmatter } from "../../lib/types";
import { GLOBAL } from "../../lib/variables";
import Anchor from "../common/Anchor.astro";
import ProjectSnippet from "../ProjectSnippet.astro";

type Props = {
  featuredProjects: Array<ProjectFrontmatter>;
}

const { featuredProjects } = Astro.props;
---

<div class="flex justify-between items-center w-full mb-8">
  <h3 class="font-display text-xl sm:text-2xl font-bold" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">{GLOBAL.projectsName}</h3>
  <Anchor url="/projects" class="text-base font-medium" style="color: var(--accent);">{GLOBAL.viewAll}</Anchor>
</div>
<ul class="my-4">
  {
    (featuredProjects.length === 0 && <p>{GLOBAL.noProjects}</p>) ||
      featuredProjects.map((project) => (
        <li>
          <ProjectSnippet
            title={project.title}
            description={project.description}
            url={project.filename}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            tags={project.tags ?? []}
          />
        </li>
      ))
  }
</ul>