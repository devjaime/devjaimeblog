---
import type { ProjectFrontmatter } from "../../lib/types";
import { routes, ui, type Locale } from "../../i18n/ui";
import Anchor from "../common/Anchor.astro";
import ProjectSnippet from "../ProjectSnippet.astro";

type Props = {
  featuredProjects: Array<ProjectFrontmatter>;
  lang?: Locale;
}

const { featuredProjects, lang = "es" } = Astro.props;
const t = ui[lang].projects;
---

<section class="projects-section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.title}</h2>
      <p>{t.intro}</p>
    </div>
    <Anchor url={routes[lang].projects} class="view-link">{t.viewAll}</Anchor>
  </div>

  <ul class="project-list">
    {(featuredProjects.length === 0 && <p>No projects yet.</p>) ||
      featuredProjects.slice(0, 4).map((project) => (
        <li>
          <ProjectSnippet
            title={project.title}
            description={project.description}
            url={project.filename}
            githubUrl={project.githubUrl}
            liveUrl={project.liveUrl}
            tags={project.tags ?? []}
          />
        </li>
      ))
    }
  </ul>
</section>

<style>
  .projects-section {
    padding: 4rem 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h2 {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0;
  }

  .section-heading p:not(.eyebrow) {
    max-width: 660px;
    color: var(--on-surface-variant);
  }

  .project-list {
    display: grid;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--surface-stroke);
  }

  @media (max-width: 720px) {
    .section-heading {
      display: block;
    }

    .view-link {
      display: inline-flex;
      margin-top: 1rem;
    }
  }
</style>
