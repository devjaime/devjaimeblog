---
import { ui, type Locale } from "../../i18n/ui";

const { lang = "es" } = Astro.props as { lang?: Locale };
const stack = ui[lang].stack;
---

<section class="capabilities-section">
  <div class="section-heading">
    <p class="eyebrow">{stack.eyebrow}</p>
    <h2>{stack.title}</h2>
  </div>

  <div class="capability-grid">
    {stack.capabilities.map((capability) => (
      <article class="capability-card">
        <h3>{capability.title}</h3>
        <p>{capability.text}</p>
        <div class="capability-items">
          {capability.items.map((item) => <span>{item}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .capabilities-section {
    padding: 3.5rem 0;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0;
  }

  h2 {
    max-width: 800px;
    margin-top: 0.35rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0;
  }

  .capability-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2rem;
  }

  .capability-card {
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.68);
    padding: 1.4rem;
  }

  .capability-card h3 {
    margin-bottom: 0.75rem;
    font-size: 1.2rem;
    letter-spacing: 0;
  }

  .capability-card p {
    color: var(--on-surface-variant);
  }

  .capability-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 1.25rem;
  }

  .capability-items span {
    border: 1px solid rgba(37, 99, 235, 0.18);
    border-radius: 999px;
    color: var(--primary);
    background: rgba(37, 99, 235, 0.06);
    padding: 0.35rem 0.6rem;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.72rem;
  }

  @media (max-width: 860px) {
    .capability-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
