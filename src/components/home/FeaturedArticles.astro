---
import type { ArticleFrontmatter } from "../../lib/types";
import { GLOBAL } from "../../lib/variables";
import ArticleSnippet from "../ArticleSnippet.astro";
import Anchor from "../common/Anchor.astro";

type Props = {
  featuredArticles: Array<ArticleFrontmatter>;
}

const { featuredArticles } = Astro.props;
---

<div class="flex justify-between items-center w-full mb-8">
  <h3 class="font-display text-xl sm:text-2xl font-bold" style="font-family: 'Plus Jakarta Sans', system-ui, sans-serif;">{GLOBAL.articlesName}</h3>
  <Anchor url="/blog" class="text-base font-medium" style="color: var(--accent);">{GLOBAL.viewAll}</Anchor>
</div>
<ul class="my-4 grid gap-4">
  {
    (featuredArticles.length === 0 && <p>{GLOBAL.noArticles}</p>) ||
      featuredArticles.map((article) => (
        <li>
          <ArticleSnippet
            title={article.title}
            description={article.description}
            url={article.filename}
            timestamp={article.timestamp}
            duration={`${article.time} min`}
          />
        </li>
      ))
  }
</ul>