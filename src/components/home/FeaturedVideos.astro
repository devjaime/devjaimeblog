---
import { featuredVideos } from "../../data/videos";
import { routes, ui, type Locale } from "../../i18n/ui";
import VideoCard from "../VideoCard.astro";

const { lang = "es" } = Astro.props as { lang?: Locale };
const t = ui[lang].videos;
---

<section class="videos-section">
  <div class="section-heading">
    <div>
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.featuredTitle}</h2>
      <p>{t.intro}</p>
    </div>
    <a href={routes[lang].videos} class="view-link">{t.viewAll}</a>
  </div>

  <div class="video-grid">
    {featuredVideos.slice(0, 3).map((video) => <VideoCard video={video} lang={lang} />)}
  </div>
</section>

<style>
  .videos-section {
    padding: 4rem 0;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 1.5rem;
  }

  .eyebrow {
    color: var(--primary);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  h2 {
    margin: 0.25rem 0 0.75rem;
    font-size: clamp(2rem, 4vw, 3.2rem);
    letter-spacing: 0;
  }

  .section-heading p:not(.eyebrow) {
    max-width: 660px;
    color: var(--on-surface-variant);
  }

  .view-link {
    color: var(--primary);
    font-weight: 800;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 920px) {
    .video-grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      display: block;
    }
  }
</style>
