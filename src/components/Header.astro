---
import { GLOBAL } from "../lib/variables";

const labels: Record<string, string> = {
  home: "Inicio",
  about: "Sobre mí",
  projects: "Proyectos",
  blog: "Blog",
  services: "Servicios",
  contact: "Contacto",
  cv: "CV",
};
---

<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Ir al inicio">
      <strong>devjaime</strong>
      <span>AI & Software Engineering</span>
    </a>

    <button
      class="menu-button"
      aria-label="Abrir navegación"
      aria-expanded="false"
      aria-controls="main-navigation"
      id="menu-toggle"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="main-navigation" class="main-nav" aria-label="Navegación principal">
      {Object.entries(GLOBAL.menu).map(([key, url]) => (
        <a href={url} aria-current={Astro.url.pathname === url ? "page" : undefined}>{labels[key] ?? key}</a>
      ))}
    </nav>
  </div>
</header>

<script is:inline>
  const button = document.querySelector("#menu-toggle");
  const nav = document.querySelector("#main-navigation");

  button?.addEventListener("click", () => {
    const expanded = button.getAttribute("aria-expanded") === "true";
    button.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("is-open", !expanded);
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--surface-stroke);
    background: rgba(250, 250, 247, 0.9);
    backdrop-filter: blur(18px);
  }

  .header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0.9rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    color: var(--on-surface);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .brand strong {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0;
  }

  .brand span {
    color: var(--on-surface-variant);
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 0.68rem;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .main-nav a {
    color: var(--on-surface-variant);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
  }

  .main-nav a:hover,
  .main-nav a[aria-current="page"] {
    color: var(--primary);
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    border: 1px solid var(--surface-stroke);
    border-radius: 8px;
    background: #fff;
    padding: 0.65rem;
  }

  .menu-button span {
    display: block;
    height: 2px;
    background: var(--on-surface);
    margin: 5px 0;
  }

  @media (max-width: 760px) {
    .menu-button {
      display: block;
    }

    .main-nav {
      position: absolute;
      inset: 100% 1rem auto 1rem;
      display: none;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      border: 1px solid var(--surface-stroke);
      border-radius: 8px;
      background: #fff;
      padding: 0.5rem;
      box-shadow: 0 18px 40px rgba(15, 23, 42, 0.1);
    }

    .main-nav.is-open {
      display: flex;
    }

    .main-nav a {
      padding: 0.8rem;
    }
  }
</style>
